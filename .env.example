# SentinelACS — exemplo de configuração
# Copie para .env e ajuste. NUNCA commitar .env.
#
# Para PRODUÇÃO no servidor: o init-secrets.sh gera /opt/sentinelacs/config/.env
# automaticamente com secrets aleatórios. Este arquivo é só para dev local.

# ──────────────── Aplicação ────────────────
APP_ENV=development                  # development | staging | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_SESSION_SECRET=troque-com-openssl-rand-base64-32
APP_AGE_KEY_FILE=/run/secrets/age.key
APP_SHUTDOWN=15s

# ──────────────── PostgreSQL + TimescaleDB ────────────────
POSTGRES_DB=sentinelacs
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=troque-em-producao
DATABASE_URL=postgres://sentinel:troque-em-producao@postgres:5432/sentinelacs?sslmode=disable

# ──────────────── Redis ────────────────
REDIS_PASSWORD=troque-em-producao
REDIS_URL=redis://default:troque-em-producao@redis:6379/0

# ──────────────── GenieACS ────────────────
GENIEACS_NBI_URL=http://genieacs-nbi:7557
GENIEACS_FS_URL=http://genieacs-fs:7567
GENIEACS_AUTH_USER=
GENIEACS_AUTH_PASS=

# ──────────────── ERP Voalle ────────────────
VOALLE_BASE_URL=
VOALLE_CLIENT_ID=
VOALLE_CLIENT_SECRET=
VOALLE_TIMEOUT=30s
VOALLE_SYNC_INTERVAL=5m

# ──────────────── Notifiers (Fase 5) ────────────────
# Cada canal é independente — preenchidos = habilitados, vazios = ignorados.

# WhatsApp via Evolution API (self-hosted)
NOTIFIER_WHATSAPP_BASE_URL=
NOTIFIER_WHATSAPP_API_KEY=
NOTIFIER_WHATSAPP_INSTANCE=

# Telegram (Bot API direta)
NOTIFIER_TELEGRAM_BOT_TOKEN=

# SMTP (stdlib net/smtp + STARTTLS)
NOTIFIER_SMTP_HOST=
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USERNAME=
NOTIFIER_SMTP_PASSWORD=
NOTIFIER_SMTP_FROM_ADDRESS=
NOTIFIER_SMTP_FROM_NAME=SentinelACS Alerts

# ──────────────── Observabilidade ────────────────
LOG_LEVEL=info                       # debug | info | warn | error
LOG_FORMAT=json                      # json | text

# ──────────────── Deploy / Compose ────────────────
PUBLIC_HOST=acs.exemplo.com.br
TRAEFIK_ACME_EMAIL=admin@exemplo.com.br
IMAGE_TAG=ghcr.io/celinet/sentineltr069:latest

# ──────────────── Backup off-site (opcional) ────────────────
# Backblaze B2 via rclone — configure rclone manual com 'rclone config'.
BACKUP_B2_BUCKET=
BACKUP_B2_KEY_ID=
BACKUP_B2_APPLICATION_KEY=
BACKUP_RETENTION_DAYS=30

# ──────────────── Telegram dedicado a deploys (opcional) ────────────────
# Chat ID separado do TELEGRAM bot para notificar deploys (success/fail).
TELEGRAM_DEPLOY_CHAT=
