# SentinelACS — exemplo de configuração
# Copie para .env e ajuste. NUNCA commitar .env.

# ──────────────── Aplicação ────────────────
APP_ENV=development                  # development | staging | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_SESSION_SECRET=troque-em-producao-com-openssl-rand-hex-32
APP_AGE_KEY_FILE=/run/secrets/age.key   # chave de cifragem de segredos (fora do banco)

# ──────────────── PostgreSQL + TimescaleDB ────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=troque-em-producao
DATABASE_URL=postgres://sentinel:troque-em-producao@postgres:5432/sentinel?sslmode=disable

# ──────────────── Redis ────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=troque-em-producao
REDIS_URL=redis://:troque-em-producao@redis:6379/0

# ──────────────── GenieACS ────────────────
# Em dev: instância no docker-compose (genieacs-nbi:7557).
# Em prod (servidor da empresa): aponte para a instância real, mantendo NBI fora da rede pública.
GENIEACS_NBI_URL=http://genieacs-nbi:7557
GENIEACS_FS_URL=http://genieacs-fs:7567
GENIEACS_AUTH_USER=
GENIEACS_AUTH_PASS=

# ──────────────── ERP Voalle ────────────────
VOALLE_BASE_URL=https://api.voalle.cliente.com.br
VOALLE_CLIENT_ID=
VOALLE_CLIENT_SECRET=
VOALLE_TIMEOUT=30s
VOALLE_SYNC_INTERVAL=5m

# ──────────────── FreeRADIUS (leitura radacct) ────────────────
# Banco do FreeRADIUS já existente na rede da empresa.
# Dialeto: "postgres" ou "mysql".
FREERADIUS_DIALECT=postgres
FREERADIUS_DSN=postgres://radread:senha@10.0.0.10:5432/radius?sslmode=disable

# ──────────────── Notificações ────────────────
# WhatsApp via Evolution API (self-hosted)
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=sentinel

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sentinel@empresa.com.br

# ──────────────── Observabilidade ────────────────
LOG_LEVEL=info                       # debug | info | warn | error
LOG_FORMAT=json                      # json | text
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_ENABLED=true

# ──────────────── Deploy (CI/CD) ────────────────
IMAGE_TAG=latest
